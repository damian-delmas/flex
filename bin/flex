#!/usr/bin/env python3
"""
flex — sandboxed CLI for flexsearch cells.

Three sandboxes:
  flex search "SELECT ..."         Read-only SQL
  flex search @introspect          Named preset
  flex search @digest days=7       Preset with params
  flex meditate                    Graph rebuild (_enrich_* only)
  flex index [path]                Ingest pipeline (_raw_*, _edges_*)

Options:
  --cell NAME                      Cell name (default: thread)
"""

import argparse
import json
import sqlite3
import sys
from pathlib import Path

CELLS_ROOT = Path.home() / ".qmem/cells/projects"


def resolve_cell(name: str) -> Path:
    db_path = CELLS_ROOT / name / "main.db"
    if not db_path.exists():
        print(f"Cell not found: {db_path}", file=sys.stderr)
        sys.exit(1)
    return db_path


def cmd_search(db: sqlite3.Connection, query: str, cell_dir: Path):
    """Search sandbox: read-only SQL or @preset."""
    if query.startswith('@'):
        # Preset execution from _presets table
        parts = query[1:].split()
        preset_name = parts[0]
        params = {}
        for p in parts[1:]:
            if '=' in p:
                k, v = p.split('=', 1)
                try:
                    params[k] = int(v)
                except ValueError:
                    params[k] = v

        from flexsearch.retrieve.presets import PresetLoader
        loader = PresetLoader(db)
        if preset_name not in loader.list_presets():
            available = loader.list_presets()
            print(f"Preset not found: {preset_name}", file=sys.stderr)
            if available:
                print(f"Available: {', '.join(available)}", file=sys.stderr)
            sys.exit(1)
        results = loader.execute(db, preset_name, params)
        print(json.dumps(results, indent=2, default=str))
        return

    # Raw SQL — read-only enforcement
    sql = query.strip()
    upper = sql.upper()
    write_keywords = ('INSERT', 'UPDATE', 'DELETE', 'DROP', 'CREATE', 'ALTER')
    for kw in write_keywords:
        if upper.startswith(kw):
            print(f"search sandbox is read-only (rejected: {kw})", file=sys.stderr)
            sys.exit(1)

    # Materialize vec_search() table sources into temp tables
    from flexsearch.retrieve.vec_search import materialize_vec_search
    sql = materialize_vec_search(db, sql)

    try:
        rows = db.execute(sql).fetchall()
        results = [dict(r) for r in rows]
        print(json.dumps(results, indent=2, default=str))
    except sqlite3.OperationalError as e:
        print(f"SQL error: {e}", file=sys.stderr)
        sys.exit(1)


def cmd_meditate(db: sqlite3.Connection, args):
    """Meditate sandbox: graph rebuild, writes _enrich_* only."""
    from flexsearch.manage.meditate import (
        build_similarity_graph, compute_scores, persist
    )
    from flexsearch.views import regenerate_views

    where = args.where if hasattr(args, 'where') and args.where else None
    threshold = args.threshold if hasattr(args, 'threshold') else 0.5

    print("Building similarity graph...")
    G = build_similarity_graph(db, threshold=threshold, where=where)

    print("Computing scores...")
    scores = compute_scores(G)

    print(f"Persisting {len(scores)} scores...")
    persist(db, scores)
    regenerate_views(db)

    hubs = sum(1 for s in scores if s[2])  # is_hub
    comms = len(set(s[4] for s in scores))  # community_id
    print(f"Done: {len(scores)} sources, {hubs} hubs, {comms} communities")


def cmd_index(db: sqlite3.Connection, args):
    """Index sandbox: invoke external compiler. Full write access."""
    print("Index sandbox — invoke an external compiler script.")
    print("Example: python scripts/init-docpac.py --corpus /path --cell /path")
    print("The flex index command will integrate with registered compilers in Plan 5.")


def main():
    parser = argparse.ArgumentParser(
        prog='flex',
        description='Flexsearch CLI — sandboxed access to knowledge cells'
    )
    parser.add_argument('--cell', default='thread', help='Cell name (default: thread)')

    sub = parser.add_subparsers(dest='command')

    # search
    search_p = sub.add_parser('search', aliases=['s'], help='Read-only SQL or @preset')
    search_p.add_argument('query', help='SQL string or @preset_name [params]')

    # meditate
    med_p = sub.add_parser('meditate', aliases=['m'], help='Rebuild graph enrichments')
    med_p.add_argument('--threshold', type=float, default=0.5)
    med_p.add_argument('--where', default=None, help='SQL WHERE filter for graph building')

    # index
    idx_p = sub.add_parser('index', aliases=['i'], help='Ingest pipeline')
    idx_p.add_argument('path', nargs='?', help='Corpus path')

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(1)

    # Resolve cell
    cell_name = args.cell
    db_path = resolve_cell(cell_name)
    cell_dir = db_path.parent

    from flexsearch.core import open_cell
    db = open_cell(str(db_path))

    if args.command in ('search', 's'):
        cmd_search(db, args.query, cell_dir)
    elif args.command in ('meditate', 'm'):
        cmd_meditate(db, args)
    elif args.command in ('index', 'i'):
        cmd_index(db, args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
